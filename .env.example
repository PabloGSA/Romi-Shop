# ============================================================
# VARIABLES DE ENTORNO - copia este archivo como .env.local
# y rellena con tus valores reales
# ============================================================

# ── MongoDB Atlas ──────────────────────────────────────────
# 1. Ve a cloud.mongodb.com
# 2. Crea un cluster gratuito (M0 Free)
# 3. En "Connect" → "Drivers" copia la cadena de conexión
# 4. Reemplaza <password> con tu contraseña
MONGODB_URI=mongodb+srv://<usuario>:<password>@cluster0.xxxxx.mongodb.net/bisuteria?retryWrites=true&w=majority

# ── NextAuth ───────────────────────────────────────────────
# La URL de tu aplicación
NEXTAUTH_URL=http://localhost:3000

# Clave secreta para firmar los tokens JWT
# Genera una con: openssl rand -base64 32
# O usa cualquier string largo y aleatorio
NEXTAUTH_SECRET=pon-aqui-una-cadena-larga-y-secreta-aleatoria

# ── Stripe ─────────────────────────────────────────────────
# 1. Ve a dashboard.stripe.com
# 2. Modo TEST (no cobras dinero real)
# 3. Developers → API Keys
STRIPE_SECRET_KEY=sk_test_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
# Esta clave va en el FRONTEND (es pública, no importa que se vea)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Clave secreta del webhook (para verificar que los avisos vienen de Stripe)
# 1. Ve a dashboard.stripe.com → Developers → Webhooks
# 2. Crea un endpoint con URL: https://tu-dominio.com/api/webhook
# 3. Evento a escuchar: checkout.session.completed
# 4. Copia el "Signing secret" que empieza por whsec_
# Para desarrollo local usa el Stripe CLI: stripe listen --forward-to localhost:3000/api/webhook
STRIPE_WEBHOOK_SECRET=whsec_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ── Resend (emails) ────────────────────────────────────────
# 1. Ve a resend.com y crea una cuenta gratuita (no necesitas tarjeta)
# 2. En el dashboard crea un API Key
# 3. Pégalo aquí
RESEND_API_KEY=re_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ── Email List Verify (validación de emails en el registro) ─
# 1. Ve a app.emaillistverify.com/signup
# 2. Crea una cuenta gratuita (incluye 100 verificaciones gratis)
# 3. Ve a la sección API y copia tu API Key
EMAIL_LIST_VERIFY_API_KEY=XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

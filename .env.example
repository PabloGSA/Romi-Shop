# ============================================================
# VARIABLES DE ENTORNO - copia este archivo como .env.local
# y rellena con tus valores reales
# ============================================================

# ── MongoDB Atlas ──────────────────────────────────────────
# 1. Ve a cloud.mongodb.com
# 2. Crea un cluster gratuito (M0 Free)
# 3. En "Connect" → "Drivers" copia la cadena de conexión
# 4. Reemplaza <password> con tu contraseña
MONGODB_URI=mongodb+srv://<usuario>:<password>@cluster0.xxxxx.mongodb.net/bisuteria?retryWrites=true&w=majority

# ── NextAuth ───────────────────────────────────────────────
# La URL de tu aplicación
NEXTAUTH_URL=http://localhost:3000

# Clave secreta para firmar los tokens JWT
# Genera una con: openssl rand -base64 32
# O usa cualquier string largo y aleatorio
NEXTAUTH_SECRET=pon-aqui-una-cadena-larga-y-secreta-aleatoria

# ── Stripe ─────────────────────────────────────────────────
# 1. Ve a dashboard.stripe.com
# 2. Modo TEST (no cobras dinero real)
# 3. Developers → API Keys
STRIPE_SECRET_KEY=sk_test_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
# Esta clave va en el FRONTEND (es pública, no importa que se vea)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
